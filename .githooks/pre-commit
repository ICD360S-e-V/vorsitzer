#!/usr/bin/env bash
# Pre-commit hook: block commits that introduce secrets.
# Activated by `git config core.hooksPath .githooks` (see scripts/install-hooks.ps1).
#
# Scans only STAGED CHANGES (gitleaks protect --staged), not the full repo,
# so commits unrelated to known-leaked files are not blocked.
#
# To bypass in an emergency (do not use for production secrets):
#   git commit --no-verify

set -e

# Locate gitleaks: PATH first, then the winget default install location
GITLEAKS=""
if command -v gitleaks >/dev/null 2>&1; then
  GITLEAKS="gitleaks"
elif [ -x "$LOCALAPPDATA/Microsoft/WinGet/Packages/Gitleaks.Gitleaks_Microsoft.Winget.Source_8wekyb3d8bbwe/gitleaks.exe" ]; then
  GITLEAKS="$LOCALAPPDATA/Microsoft/WinGet/Packages/Gitleaks.Gitleaks_Microsoft.Winget.Source_8wekyb3d8bbwe/gitleaks.exe"
else
  # Try Windows-style path expansion as fallback
  WINPATH="$(cygpath -u "$LOCALAPPDATA" 2>/dev/null || echo "$LOCALAPPDATA")"
  if [ -x "$WINPATH/Microsoft/WinGet/Packages/Gitleaks.Gitleaks_Microsoft.Winget.Source_8wekyb3d8bbwe/gitleaks.exe" ]; then
    GITLEAKS="$WINPATH/Microsoft/WinGet/Packages/Gitleaks.Gitleaks_Microsoft.Winget.Source_8wekyb3d8bbwe/gitleaks.exe"
  fi
fi

if [ -z "$GITLEAKS" ]; then
  echo "❌ gitleaks not found. Install:"
  echo "    winget install --id gitleaks.gitleaks"
  echo "Then re-run: git config core.hooksPath .githooks"
  exit 1
fi

# Scan staged changes against .gitleaks.toml
"$GITLEAKS" protect --staged --no-banner -c .gitleaks.toml || {
  echo ""
  echo "❌ gitleaks found secrets in staged changes — commit blocked."
  echo "   Move secrets to GitHub Secrets + --dart-define, or to /api/config.php on server."
  echo "   To bypass (NEVER for production secrets): git commit --no-verify"
  exit 1
}
