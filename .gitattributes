# Auto detect text files and perform LF normalization
*        text=auto

# Always perform LF normalization on these files
*.c              text
*.cc             text
*.cmake          text
*.cpp            text
*.dart           text
*.gradle         text
*.gradle.kts     text
*.h              text
*.html           text
*.java           text
*.json           text
*.kt             text
*.kts            text
*.md             text
*.php            text
*.plist          text
*.py             text
*.storyboard     text
*.svg            text
*.swift          text
*.toml           text
*.txt            text
*.xcconfig       text
*.xib            text
*.xml            text
*.yaml           text
*.yml            text
*.entitlements   text
*.pbxproj        text
*.xcworkspacedata text
.flutter-plugins-dependencies text

# Linux/Unix files — always LF in checkout
*.sh              text eol=lf
bin/*             text eol=lf
.githooks/*       text eol=lf

# Windows files — always CRLF in checkout
*.bat             text eol=crlf
*.ps1             text eol=crlf
*.rc              text eol=crlf
*.sln             text eol=crlf
*.props           text eol=crlf
*.vcxproj         text eol=crlf
*.vcxproj.filters text eol=crlf
*.iss             text eol=crlf

# Never perform LF normalization on these files
*.ico    binary
*.jar    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.zip    binary
*.gz     binary
*.tar    binary
*.ttf    binary
*.otf    binary
*.woff   binary
*.woff2  binary
*.pdf    binary
